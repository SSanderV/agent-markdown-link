{
  "description": "Load explicitly configured curated Markdown at session start.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "plugin:agent-markdown-link:memory",
            "tool": "context",
            "input": {
              "hookEventName": "SessionStart",
              "sessionId": "${session_id}"
            },
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "plugin:agent-markdown-link:memory",
            "tool": "context",
            "input": {
              "hookEventName": "UserPromptSubmit",
              "sessionId": "${session_id}"
            },
            "timeout": 10
          }
        ]
      }
    ]
  }
}
